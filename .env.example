# Glyphwright frontend env config.
# Copy to `.env` (or `.env.local`) and fill in.

# Address printed by `genlayer deploy` (or copied from the Studio web UI
# after you deploy contracts/glyphwright.py manually).
# Format: 0x followed by 40 hex chars.
# If left empty, the Forge page will show a paste-the-address banner you
# can fill in at runtime — no rebuild required.
VITE_GLYPHWRIGHT_CONTRACT=
